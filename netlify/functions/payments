exports.handler = async (event, context) => {
  try {
    const data = JSON.parse(event.body || "{}");

    const produto = data.produto || "Conta Avakin";
    const valor = data.valor || 1.00;

    // Aqui depois vamos integrar com Efí
    return {
      statusCode: 200,
      body: JSON.stringify({
        message: "Pagamento criado",
        produto,
        valor
      })
    };

  } catch (error) {
    return {
      statusCode: 500,
      body: JSON.stringify({
        error: "Erro ao criar pagamento"
      })
    };
  }
};
